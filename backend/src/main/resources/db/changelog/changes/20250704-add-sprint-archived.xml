<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <!-- Additive: sprint archiving flag for the Trello-like sprint lifecycle. -->
    <changeSet id="20250704-add-sprint-archived" author="claude">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="sprint" columnName="archived"/></not>
        </preConditions>
        <addColumn tableName="sprint">
            <column name="archived" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
