<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <!-- Additive: flag to avoid sending duplicate 15-min meeting reminders. -->
    <changeSet id="20250711-add-meeting-reminder-sent" author="claude">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="meeting" columnName="reminder_sent"/></not>
        </preConditions>
        <addColumn tableName="meeting">
            <column name="reminder_sent" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
