<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <!-- Additive: in-app notifications (mentions). No email/push/realtime. -->
    <changeSet id="20250706-add-notification-table" author="claude">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="notification"/></not>
        </preConditions>
        <createTable tableName="notification">
            <column name="id" type="varchar(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="recipient_id" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="actor_id" type="varchar(255)"/>
            <column name="type" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="message" type="varchar(1024)"/>
            <column name="task_id" type="varchar(255)"/>
            <column name="comment_id" type="varchar(255)"/>
            <column name="is_read" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="notification" baseColumnNames="recipient_id"
                                 constraintName="fk_notification_recipient"
                                 referencedTableName="users" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="notification" baseColumnNames="actor_id"
                                 constraintName="fk_notification_actor"
                                 referencedTableName="users" referencedColumnNames="id"/>
        <createIndex tableName="notification" indexName="idx_notification_recipient">
            <column name="recipient_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
