<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <!--
      Additive: give every EXISTING project a "Backlog" Kanban column.
      New projects already get it via StatusName defaults. Idempotent via NOT EXISTS;
      priority 0 keeps it left-most and avoids colliding with existing priorities (1..5).
      default_task_status stays false here so existing projects keep their current default.
    -->
    <changeSet id="20250703-add-backlog-column" author="claude" dbms="postgresql">
        <sql>
            INSERT INTO task_status (id, priority, code, description, viewed, default_task_status, project_id)
            SELECT nextval(pg_get_serial_sequence('task_status', 'id')), 0, 'BACKLOG', 'Бэклог', true, false, p.id
            FROM project p
            WHERE NOT EXISTS (
                SELECT 1 FROM task_status ts WHERE ts.project_id = p.id AND ts.code = 'BACKLOG'
            );
        </sql>
        <rollback/>
    </changeSet>

</databaseChangeLog>
