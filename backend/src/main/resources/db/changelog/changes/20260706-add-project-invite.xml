<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <!-- ТП-35: одноразовые ссылки-приглашения в проект. id — сам токен (UUID),
         used_by фиксирует, кем ссылка израсходована. -->
    <changeSet id="20260706-add-project-invite" author="cloud-code">
        <createTable tableName="project_invite">
            <column name="id" type="VARCHAR(36)">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="project_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_invite_project" references="project(id)"/>
            </column>
            <column name="created_by_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_invite_creator" references="users(id)"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="used_by_id" type="VARCHAR(36)">
                <constraints nullable="true" foreignKeyName="fk_invite_used_by" references="users(id)"/>
            </column>
            <column name="used_at" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
        </createTable>
        <createIndex tableName="project_invite" indexName="idx_invite_project">
            <column name="project_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
